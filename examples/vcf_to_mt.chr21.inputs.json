{
  "hailrunner_run.project": "broad-dsde-methods",
  "hailrunner_run.script": "https://raw.githubusercontent.com/broadinstitute/hailrunner/main/examples/vcf_to_mt.py",
  "hailrunner_run.script_args": [
    "--vcf", "gs://prod-drc-broad/aou_phasing/v9/chr21.aou.v9.phased.vcf.gz",
    "--mt-output", "gs://broad-dsde-methods/hailrunner/output/chr21.aou.v9.phased.mt"
  ],
  "hailrunner_run.workers": 16,
  "hailrunner_run.preemptibles": 32,
  "hailrunner_run.driver_type": "n1-standard-16",
  "hailrunner_run.worker_type": "n1-highmem-8",
  "hailrunner_run.worker_disk_gb": 500,
  "hailrunner_run.driver_disk_gb": 1024,
  "hailrunner_run.max_idle": 30
}
